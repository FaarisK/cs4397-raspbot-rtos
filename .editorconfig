root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
tab_width = 4
trim_trailing_whitespace = true
continuation_indent_size = 8

[*.{yml,yaml,md,markdown,txt,lua,json}]
indent_size = 2

[*.{css,js,jsx,mjs,cjs,ts,tsx,mts,cts,vue}]
indent_size = 4

[*.{sh,bash,inc,command}]
indent_style = tab
indent_size = 4